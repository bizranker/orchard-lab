resource "aws_security_group" "gitlab" {
  name        = "${var.name_prefix}-gitlab-sg"
  description = "GitLab host SG"
  vpc_id      = data.aws_vpc.default.id

  # HTTP from ALB only
  ingress {
    description     = "HTTP from ALB"
    from_port       = 80
    to_port         = 80
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
  }

  # SSH from your IP (update this!)
  ingress {
    description = "SSH from my IP"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = [var.my_ip_cidr]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = { Name = "${var.name_prefix}-gitlab-sg" }
}

resource "aws_instance" "gitlab" {
  ami                         = data.aws_ami.al2023.id
  instance_type               = var.instance_type
  subnet_id                   = data.aws_subnets.default.ids[0]
  vpc_security_group_ids      = [aws_security_group.gitlab.id]
  associate_public_ip_address = true

  user_data = <<-EOF
#!/bin/bash
set -euxo pipefail
dnf -y update
dnf -y install curl policycoreutils openssh-server perl
systemctl enable --now sshd

# GitLab Omnibus install (Amazon Linux / RHEL family)
curl -s https://packages.gitlab.com/install/repositories/gitlab/gitlab-ee/script.rpm.sh | bash
EXTERNAL_URL="http://gitlab.orchard-lab.usreliance.com" dnf -y install gitlab-ee
gitlab-ctl reconfigure
EOF

  tags = {
    Name = "${var.name_prefix}-gitlab"
  }
}

resource "aws_lb_target_group" "gitlab" {
  name     = "orchard-gitlab-tg"
  port     = 80
  protocol = "HTTP"
  vpc_id   = data.aws_vpc.default.id

  health_check {
    path                = "/users/sign_in"
    matcher             = "200-399"
    interval            = 30
    timeout             = 5
    healthy_threshold   = 2
    unhealthy_threshold = 2
  }

  tags = { Name = "orchard-gitlab-tg" }
}

resource "aws_lb_target_group_attachment" "gitlab" {
  target_group_arn = aws_lb_target_group.gitlab.arn
  target_id        = aws_instance.gitlab.id
  port             = 80
}

resource "aws_lb_listener_rule" "gitlab_host" {
  listener_arn = aws_lb_listener.https.arn
  priority     = 10

  action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.gitlab.arn
  }

  condition {
    host_header {
      values = ["gitlab.orchard-lab.usreliance.com"]
    }
  }
}